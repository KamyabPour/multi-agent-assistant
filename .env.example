# Backend
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
OPENAI_API_KEY=
DEFAULT_MODEL=gpt-4.1-mini

# GitHub Models API (AI Brain) - https://github.com/models
GITHUB_TOKEN=
GITHUB_MODELS_ENABLED=false
GITHUB_MODELS_MODEL=gpt-4o-mini
GITHUB_MODELS_TIMEOUT=30

# Gmail Integration
ASSISTANT_EMAIL_ENABLED=false
ASSISTANT_EMAIL_PROVIDER=gmail_smtp
ASSISTANT_EMAIL_FROM=
ASSISTANT_EMAIL_APP_PASSWORD=
ASSISTANT_EMAIL_SMTP_HOST=smtp.gmail.com
ASSISTANT_EMAIL_SMTP_PORT=587
ASSISTANT_EMAIL_USE_STARTTLS=true

# Frontend endpoints
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
